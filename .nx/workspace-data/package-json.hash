      "format": {
        "executor": "nx:run-script",
        "options": {
          "script": "format"
        },
        "metadata": {
          "scriptContent": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
          "runCommand": "pnpm run format"
        }
      },
      "start": {
        "executor": "nx:run-script",
        "options": {
          "script": "start"
        },
        "metadata": {
