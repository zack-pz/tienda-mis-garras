        }
      },
      "test:e2e": {
        "executor": "nx:run-script",
        "options": {
          "script": "test:e2e"
        },
        "metadata": {
          "scriptContent": "jest --config ./test/jest-e2e.json",
          "runCommand": "pnpm run test:e2e"
        }
