  "3198825935423248298": {
    "root": "dashboard",
    "name": "dashboard",
    "targets": {
      "dev": {
        "executor": "nx:run-script",
        "options": {
          "script": "dev"
        },
        "metadata": {
          "scriptContent": "vite dev",
          "runCommand": "pnpm run dev"
        }
      },
      "build": {
        "executor": "nx:run-script",
        "options": {
          "script": "build"
        },
        "metadata": {
          "scriptContent": "vite build",
          "runCommand": "pnpm run build"
        }
      },
      "preview": {
        "executor": "nx:run-script",
        "options": {
          "script": "preview"
        },
        "metadata": {
          "scriptContent": "vite preview",
          "runCommand": "pnpm run preview"
        }
      },
      "prepare": {
        "executor": "nx:run-script",
        "options": {
          "script": "prepare"
        },
        "metadata": {
          "scriptContent": "playwright install && svelte-kit sync || echo ''",
          "runCommand": "pnpm run prepare"
        }
      },
      "check": {
        "executor": "nx:run-script",
        "options": {
          "script": "check"
        },
        "metadata": {
          "scriptContent": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
          "runCommand": "pnpm run check"
        }
      },
      "check:watch": {
        "executor": "nx:run-script",
        "options": {
          "script": "check:watch"
        },
        "metadata": {
          "scriptContent": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
          "runCommand": "pnpm run check:watch"
        }
      },
      "lint": {
        "executor": "nx:run-script",
        "options": {
          "script": "lint"
        },
        "metadata": {
          "scriptContent": "prettier --check . && eslint .",
          "runCommand": "pnpm run lint"
        }
      },
      "format": {
        "executor": "nx:run-script",
        "options": {
          "script": "format"
        },
        "metadata": {
          "scriptContent": "prettier --write .",
          "runCommand": "pnpm run format"
        }
      },
      "test:unit": {
        "executor": "nx:run-script",
        "options": {
          "script": "test:unit"
        },
        "metadata": {
          "scriptContent": "vitest",
          "runCommand": "pnpm run test:unit"
        }
      },
      "test": {
        "executor": "nx:run-script",
        "options": {
          "script": "test"
        },
        "metadata": {
          "scriptContent": "npm run test:unit -- --run && npm run test:e2e",
          "runCommand": "pnpm run test"
        }
      },
      "test:e2e": {
        "executor": "nx:run-script",
        "options": {
          "script": "test:e2e"
        },
        "metadata": {
          "scriptContent": "playwright test",
          "runCommand": "pnpm run test:e2e"
        }
      }
    },
    "tags": [
      "npm:private"
    ],
    "metadata": {
      "targetGroups": {
