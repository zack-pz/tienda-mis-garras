# =========================================
# Monorepo-wide ignores
# =========================================

# Dependencies
node_modules/

# Build outputs
dist/
build/
.svelte-kit/
.output/
.turbo/
.pnpm-store/

# Test outputs
coverage/
.nyc_output/
test-results/
playwright-report/

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Temporary files
.temp/
.tmp/

# Environment files
.env
.env.*
!.env.example
!.env.test

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VS Code (keep shared workspace configs)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Hosting / deploy outputs
.vercel/
.netlify/
.wrangler/

# OS files
.DS_Store
Thumbs.db

# Tooling artifacts
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Monorepo
.nx/

# Agent workspace

